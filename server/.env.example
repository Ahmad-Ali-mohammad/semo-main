# Runtime
NODE_ENV=production
PORT=3001
TRUST_PROXY=1
PUBLIC_SERVER_URL=

# CORS (comma-separated origins). Example:
# ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com
# Leave empty to enforce same-origin in production and allow dev Vite origins in development.
ALLOWED_ORIGINS=

# Rate limits
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=30
NON_API_WRITE_RATE_LIMIT_MAX=20

# Database mode
USE_MYSQL=1
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=semo_reptile_house

# Auth / JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=12h
BOOTSTRAP_ADMIN_SECRET=CHANGE_ME_BOOTSTRAP_SECRET
PASSWORD_PBKDF2_ITERATIONS=210000

# Gmail SMTP
MAIL_ENABLED=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=Reptile House
MAIL_FROM=
MAIL_REPLY_TO=
ORDER_ADMIN_EMAILS=

# Runtime
NODE_ENV=production
PORT=3001
TRUST_PROXY=1
PUBLIC_SERVER_URL=https://YOUR_DOMAIN

# CORS
ALLOWED_ORIGINS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN

# Rate limits
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=30

# Database mode
USE_MYSQL=1
DB_HOST=localhost
DB_PORT=3306
DB_USER=semo_user
DB_PASSWORD=CHANGE_ME
DB_NAME=semo_reptile_house

# Auth / JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=12h
BOOTSTRAP_ADMIN_SECRET=CHANGE_ME_BOOTSTRAP_SECRET
